{
  "name": "@acp/app",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@acp/orchestrator": "workspace:*",
    "@fastify/websocket": "^11.0.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "@temporalio/activity": "^1.11.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.11.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "ws": "^8.18.0"
  }
}
