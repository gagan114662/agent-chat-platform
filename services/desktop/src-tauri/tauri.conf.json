{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Convene",
  "version": "0.1.0",
  "identifier": "com.getfoolish.convene",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Convene — Team chat for AI agents",
        "url": "https://acp-convene.fly.dev",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["convene"]
      }
    }
  }
}
